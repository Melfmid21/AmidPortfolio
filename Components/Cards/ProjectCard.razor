@using AmidPortfolio.Models

<MudOverlay Visible="@showVideo" Style="backdrop-filter: blur(10px); z-index:9999;background-color: rgba(0, 0, 0, 0.9);"
            DarkBackground="true"
            AutoClose="false" >

    <div class="video-viewer">

        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Class="video-close-btn"
                       OnClick="@(() => showVideo = false)" />

        <video controls
               autoplay
               class="demo-video">

            <source src="@SelectedVideoUrl"
                    type="video/mp4">

        </video>

    </div>

</MudOverlay>

<MudGrid Class="px-4">

    @for (int count = 0; count < ProjectsModel.Count; count++)
    {
        var project = ProjectsModel[count];

        if(count == 0)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="project-card-portfolio"
                          data-aos="fade-up-right"
                          data-aos-duration="1000">

                    <div class="project-image-container">

                        <MudImage Src="@project.ImageUrl"
                                  Alt="@project.Title"
                                  Class="project-image" />

                    </div>

                    <div class="project-content">

                        <MudText Typo="Typo.h5"
                                 Class="project-title-gradient">
                            @project.Title
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="project-description">
                            @project.Description
                        </MudText>

                        <div class="project-footer">

                            <MudLink OnClick="() => OpenDemoVideo(project.LiveDemoUrl)"
                                     Class="project-link">

                                Watch Demo

                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew"
                                         Size="Size.Small" />

                            </MudLink>

                            <MudButton Variant="Variant.Text"
                                       EndIcon="@Icons.Material.Filled.ArrowForward"
                                       Class="project-button">

                                Details

                            </MudButton>

                        </div>

                    </div>

                </MudPaper>
            </MudItem>
        }else if(count == 1)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="project-card-portfolio"
                          data-aos="fade-up"
                          data-aos-duration="1200">

                    <div class="project-image-container">

                        <MudImage Src="@project.ImageUrl"
                                  Alt="@project.Title"
                                  Class="project-image" />

                    </div>

                    <div class="project-content">

                        <MudText Typo="Typo.h5"
                                 Class="project-title-gradient">
                            @project.Title
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="project-description">
                            @project.Description
                        </MudText>

                        <div class="project-footer">

                            <MudLink Href="@project.LiveDemoUrl"
                                     Target="_blank"
                                     Class="project-link">

                                Watch Demo

                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew"
                                         Size="Size.Small" />

                            </MudLink>

                            <MudButton Variant="Variant.Text"
                                       EndIcon="@Icons.Material.Filled.ArrowForward"
                                       Class="project-button">

                                Details

                            </MudButton>

                        </div>

                    </div>

                </MudPaper>
            </MudItem>
        }else if(count == 2)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="project-card-portfolio"
                          data-aos="fade-up-left"
                          data-aos-duration="1000">

                    <div class="project-image-container">

                        <MudImage Src="@project.ImageUrl"
                                  Alt="@project.Title"
                                  Class="project-image" />

                    </div>

                    <div class="project-content">

                        <MudText Typo="Typo.h5"
                                 Class="project-title-gradient">
                            @project.Title
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Class="project-description">
                            @project.Description
                        </MudText>

                        <div class="project-footer">

                            <MudLink Href="@project.LiveDemoUrl"
                                     Target="_blank"
                                     Class="project-link">

                                Watch Demo

                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew"
                                         Size="Size.Small" />

                            </MudLink>

                            <MudButton Variant="Variant.Text"
                                       EndIcon="@Icons.Material.Filled.ArrowForward"
                                       Class="project-button">

                                Details

                            </MudButton>

                        </div>

                    </div>

                </MudPaper>
            </MudItem>
        }
       
    }

</MudGrid>



<style>
    .project-card-portfolio {
        background: linear-gradient( 135deg, rgba(30,41,59,.95), rgba(49,46,129,.65) );
        border: 1px solid rgba(255,255,255,.08);
        border-radius: .75rem;
        overflow: hidden;
        height: 100%;
        transition: all .35s ease;
        backdrop-filter: blur(16px);
    }

        .project-card-portfolio:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px rgba(99,102,241,.20);
        }

    .project-image-container {
        padding: 20px 20px 0 20px;
    }

    .project-image {
        width: 100%;
        height: 250px;
        object-fit: cover;
        border-radius: .5rem;
        transition: all .4s ease;
    }

    .project-card-portfolio:hover .project-image {
        transform: scale(1.03);
    }

    /**/
    .project-content {
        padding: 24px;
    }

    .project-title-gradient {
        font-weight: 700;
        background: linear-gradient( 90deg, #bfdbfe, #d8b4fe, #fbcfe8 );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .project-description {
        color: rgba(255,255,255,.70);
        min-height: 80px;
        line-height: 1.8;
    }
    /**/
    .project-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 24px;
    }

    .project-link {
        color: #60a5fa;
        display: flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
    }

        .project-link:hover {
            color: #93c5fd;
        }

    .project-button {
        background: rgba(255,255,255,.08);
        border-radius: 10px;
        color: white;
    }

    /**/
    .video-viewer {
        width: 90vw;
        max-width: 1200px;
        margin: auto;
        position: relative;
    }

    .demo-video {
        width: 100%;
        max-height: 85vh;
        border-radius: 16px;
    }

    .video-close-btn {
        position: absolute !important;
        top: 10px;
        right: 10px;
        z-index: 100;
        background: rgba(0,0,0,.55);
        backdrop-filter: blur(8px);
        color: white !important;
        transition: all .3s ease;
    }

        .video-close-btn:hover {
            background: rgba(239,68,68,.9);
            transform: rotate(90deg) scale(1.1);
        }
</style>

@code {
    int count = 0;

    private bool showVideo;
    private string SelectedVideoUrl = "";

    private List<ProjectModel> ProjectsModel = new()
    {
        new()
        {
            Title = "Reverse Vending Machine",
            Description = "ESP32-based recycling reward system that validates recyclable materials and provides incentives.",
            ImageUrl = "images/projects/autobin.png",
            Technologies = "ESP32, IoT",
            GitHubUrl = "",
            LiveDemoUrl = "videos/rvm.mp4",
        },

        new()
        {
            Title = "Engineering Management System",
            Description = "Blazor Server application used for project management, part ordering, and schedule monitoring.",
            ImageUrl = "images/projects/autobin-dashboard.png",
            Technologies = ".NET, Blazor",
            GitHubUrl = ""
        },

        new()
        {
            Title = "Inventory Receiving System",
            Description = "QR and barcode receiving system integrated with real-time inventory tracking.",
            ImageUrl = "images/projects/autobin-redeem.png",
            Technologies = "Blazor, SQL Server",
            GitHubUrl = ""
        }
    };

    private void OpenDemoVideo(string videoUrl)
    {
        SelectedVideoUrl = videoUrl;
        showVideo = true;
    }
}