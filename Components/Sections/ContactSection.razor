<MudContainer MaxWidth="MaxWidth.Small" Class="py-12">

    <MudText Typo="Typo.h3" GutterBottom="true">
        Contact Me
    </MudText>

    <MudText Typo="Typo.body1" Class="mb-6">
        Feel free to reach out for collaboration, job opportunities, or projects.
    </MudText>

    <MudPaper Class="pa-6">

        <MudGrid>

            <MudItem xs="12">

                <MudPaper Class="pa-6 text-center">

                    <MudText Typo="Typo.h5">Let's Work Together</MudText>

                    <MudText Typo="Typo.body2" Class="mt-2">
                        I'm open to job opportunities, freelance work, and collaborations.
                    </MudText>

                </MudPaper>

            </MudItem>

            <MudItem xs="12" Class="mt-4">

                <MudStack Spacing="2" AlignItems="AlignItems.Center">

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Email"
                               Href="mailto:your.email@gmail.com">
                        Email Me
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Code"
                               Href="https://github.com/your-username"
                               Target="_blank">
                        GitHub
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Business"
                               Href="https://linkedin.com/in/your-profile"
                               Target="_blank">
                        LinkedIn
                    </MudButton>

                </MudStack>

            </MudItem>

        </MudGrid>

    </MudPaper>

</MudContainer>